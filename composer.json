{
    "name": "veltphp/skeleton",
    "description": "Installable application skeleton for the Velt framework.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "velt/kernel": "dev-main",
        "velt/http": "dev-main",
        "velt/ui": "dev-main",
        "velt/database": "dev-main",
        "veltphp/cli": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "features/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../veltphp-kernel/packages/kernel",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../veltphp-http",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../velt-ui",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../velt-database",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../veltphp-cli",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/velt serve"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
