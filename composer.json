{
    "name": "velt/skeleton",
    "description": "Installable application skeleton for the Velt framework.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "bacon/bacon-qr-code": "^2.0",
        "velt/database": "^0.1.0",
        "velt/framework": "^0.1.0",
        "velt/orm": "^0.1.0",
        "velt/ui": "^0.1.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "features/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
