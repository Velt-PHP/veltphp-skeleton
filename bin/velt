#!/usr/bin/env php
<?php

declare(strict_types=1);

use Velt\Database\Migrations\Migrator;
use Velt\Database\Seeders\SeederRunner;
use App\Preview\Services\PreviewService;

$basePath = dirname(__DIR__);
$argv = $_SERVER['argv'] ?? [];
$command = $argv[1] ?? 'help';

if ($command === 'serve') {
    $host = $argv[2] ?? '127.0.0.1:8000';
    $docroot = $basePath . '/public';
    echo "Starting Velt on http://{$host}\n";
    passthru(sprintf('php -S %s -t %s', escapeshellarg($host), escapeshellarg($docroot)));
    exit(0);
}

$kernel = require $basePath . '/bootstrap/app.php';

try {
    match ($command) {
        'migrate' => migrate($basePath),
        'migrate:rollback' => rollback($basePath),
        'db:seed' => seed($basePath),
        'preview' => preview($basePath, $argv[2] ?? null),
        'kernel:check' => kernelCheck($kernel),
        'help' => help(),
        default => unknown($command),
    };
} catch (Throwable $exception) {
    fwrite(STDERR, "Velt error: {$exception->getMessage()}\n");
    exit(1);
}

function preview(string $basePath, ?string $host): void
{
    $service = new PreviewService($basePath);
    $session = $service->createSession($host);

    echo "Velt mobile preview\n";
    echo "ID: {$session['id']}\n";
    echo "URL: {$session['url']}\n";
    echo "QR image: {$session['qr_image']}\n";
    echo $service->qrTerminal((string) $session['qr_payload']);
    echo "Scan this code with the Velt Preview app.\n";
}

function migrate(string $basePath): void
{
    $executed = (new Migrator($basePath . '/database/migrations'))->migrate();

    if ($executed === []) {
        echo "Nothing to migrate.\n";
        return;
    }

    foreach ($executed as $migration) {
        echo "Migrated: {$migration}\n";
    }
}

function rollback(string $basePath): void
{
    $rolledBack = (new Migrator($basePath . '/database/migrations'))->rollback();

    if ($rolledBack === []) {
        echo "Nothing to roll back.\n";
        return;
    }

    foreach ($rolledBack as $migration) {
        echo "Rolled back: {$migration}\n";
    }
}

function seed(string $basePath): void
{
    (new SeederRunner())->run(Database\Seeders\DatabaseSeeder::class);

    echo "Database seeded.\n";
}

/**
 * @param array<string, mixed> $kernel
 */
function kernelCheck(array $kernel): void
{
    foreach (['app', 'router', 'dispatcher'] as $key) {
        if (! array_key_exists($key, $kernel)) {
            throw new RuntimeException("Kernel entry [{$key}] is missing.");
        }
    }

    echo "Velt kernel is ready.\n";
}

function help(): void
{
    echo "Velt project CLI\n";
    echo "Usage:\n";
    echo "  php bin/velt serve [host:port]\n";
    echo "  php bin/velt preview [host:port]\n";
    echo "  php bin/velt migrate\n";
    echo "  php bin/velt migrate:rollback\n";
    echo "  php bin/velt db:seed\n";
    echo "  php bin/velt kernel:check\n";
}

function unknown(string $command): void
{
    throw new InvalidArgumentException("Unknown command [{$command}]. Run php bin/velt help.");
}
