#!/usr/bin/env php
<?php
declare(strict_types=1);

// Petit binaire CLI pour le skeleton. Actuellement uniquement
// utilisé pour démarrer un serveur PHP intégré en local lors du
// développement ou des démonstrations rapides.

$argv = $_SERVER['argv'] ?? [];

$command = $argv[1] ?? 'help';

switch ($command) {
    case 'serve':
        $host = $argv[2] ?? '127.0.0.1:8000';
        $docroot = __DIR__ . '/../public';
        echo "Démarrage du serveur PHP intégré sur http://{$host}\n";
        // Lancer le serveur intégré et transmettre la sortie au terminal.
        passthru(sprintf('php -S %s -t %s', escapeshellarg($host), escapeshellarg($docroot)));
        break;
    case 'help':
    default:
        echo "Velt skeleton CLI\n";
        echo "Usage:\n";
        echo "  php bin/velt serve [host:port]   Démarrer le serveur PHP intégré (par défaut 127.0.0.1:8000)\n";
        break;
}
